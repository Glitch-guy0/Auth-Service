requirementDiagram

    requirement req_auth_service {
        id: RQ-SYS
        text: AuthService System Core
        risk: high
        verifymethod: test
    }

    %% ─────────────────────────────────────────────────────────────────
    %%  CORE AUTHENTICATION (RQ-AUTH)
    %% ─────────────────────────────────────────────────────────────────
    requirement req_auth {
        id: RQ-AUTH
        text: Core Authentication capabilities
        risk: high
        verifymethod: test
    }
    req_auth_service - contains -> req_auth

    functionalRequirement registration {
        id: FR-1
        text: User Registration (POST /auth/v1/register) creating accounts with username, email, and password.
        risk: high
        verifymethod: test
    }
    req_auth - contains -> registration

    functionalRequirement login {
        id: FR-2
        text: User Login (POST /auth/v1/authenticate) verifying email/username + password, returning JWT access token and setting secure httpOnly refresh token cookie.
        risk: high
        verifymethod: test
    }
    req_auth - contains -> login

    functionalRequirement refresh {
        id: FR-3
        text: Token Refresh (POST /auth/v1/refresh) issuing new access tokens using valid, active refresh tokens.
        risk: high
        verifymethod: test
    }
    req_auth - contains -> refresh

    functionalRequirement logout {
        id: FR-4
        text: User Logout (POST /auth/v1/logout) clearing cookies, deleting stateful database refresh token, and blacklisting access token.
        risk: high
        verifymethod: test
    }
    req_auth - contains -> logout

    %% ─────────────────────────────────────────────────────────────────
    %%  TOKEN & LIFE-CYCLE MANAGEMENT (RQ-TKN)
    %% ─────────────────────────────────────────────────────────────────
    requirement req_tkn {
        id: RQ-TKN
        text: Token Life-cycle & Security
        risk: high
        verifymethod: test
    }
    req_auth_service - contains -> req_tkn

    functionalRequirement jwt_gen {
        id: FR-5
        text: Generate short-lived JWT access tokens signed using RSA key pairs with kids.
        risk: high
        verifymethod: test
    }
    req_tkn - contains -> jwt_gen

    functionalRequirement token_rotation {
        id: FR-6
        text: Enforce Refresh Token Rotation on every refresh request, invalidating the old token and issuing a new one.
        risk: high
        verifymethod: test
    }
    req_tkn - contains -> token_rotation

    functionalRequirement key_mgt {
        id: FR-7
        text: Dynamic RSA key pair retrieval and validation through KeyManager registry.
        risk: high
        verifymethod: analysis
    }
    req_tkn - contains -> key_mgt

    functionalRequirement blacklist {
        id: FR-25
        text: Best-effort token blacklisting of logged-out access tokens in Redis with TTL matching remaining expiry.
        risk: high
        verifymethod: test
    }
    req_tkn - contains -> blacklist

    %% ─────────────────────────────────────────────────────────────────
    %%  USER ENTITY & STATES (RQ-USR)
    %% ─────────────────────────────────────────────────────────────────
    requirement req_usr {
        id: RQ-USR
        text: User Entity & Account State Management
        risk: high
        verifymethod: test
    }
    req_auth_service - contains -> req_usr

    functionalRequirement user_entity {
        id: FR-13
        text: Store core user attributes including unique id (UUID), username, email, password hash, blocked status, verification status.
        risk: high
        verifymethod: test
    }
    req_usr - contains -> user_entity

    functionalRequirement user_lookup {
        id: FR-14
        text: Support lookup of user entities by unique identifier (UUID), username, or email.
        risk: high
        verifymethod: test
    }
    req_usr - contains -> user_lookup

    functionalRequirement user_blocking {
        id: FR-15
        text: Intercept authentication attempts from blocked users, returning forbidden error code.
        risk: high
        verifymethod: test
    }
    req_usr - contains -> user_blocking

    %% ─────────────────────────────────────────────────────────────────
    %%  LOGGING & DEMOGRAPHICS (RQ-LOG)
    %% ─────────────────────────────────────────────────────────────────
    requirement req_log {
        id: RQ-LOG
        text: Analytics & Demographics Logging
        risk: high
        verifymethod: test
    }
    req_auth_service - contains -> req_log

    functionalRequirement demographics_log {
        id: FR-18
        text: Log IP address and geolocation demographics asynchronously to MongoDB collection on auth events.
        risk: high
        verifymethod: test
    }
    req_log - contains -> demographics_log
