%% Auth Guard Sequence
%% Maps to: FR-16, FR-17, FR-25
%% JwtAuthGuard + RolesGuard flow for protected endpoints
%% Most security-sensitive flow — validates access token on every request
%% Token extraction from header done by middleware before guard

sequenceDiagram
    participant Client
    participant Middleware as AuthMiddleware
    participant Guard as JwtAuthGuard
    participant TokenService
    participant KeyManager
    participant Redis
    participant Handler as Route Handler

    Client->>Middleware: Request with Authorization: Bearer <token>

    rect rgb(240, 240, 255)
        Note over Middleware: Middleware extracts token from header
        Middleware->>Middleware: Extract token from Authorization header
        Middleware->>Middleware: Attach token to request context
    end

    Middleware->>Guard: Request with token in context

    rect rgb(230, 245, 255)
        Note over Guard,Redis: Step 1: Validate JWT
        Guard->>Guard: Decode JWT header to extract kid
        Guard->>KeyManager: getPublicKey(kid)
        KeyManager-->>Guard: PublicKey
        Guard->>Guard: Verify JWT signature (RSA)
        Note right of Guard: jwt.verify(token, publicKey)
    end

    alt Invalid signature
        Guard-->>Client: 401 Unauthorized (TokenInvalidSignatureException)
    end

    rect rgb(255, 245, 230)
        Note over Guard,Redis: Step 2: Check blacklist
        Guard->>Redis: GET blacklist:{access_token}
        Redis-->>Guard: {expires_at, user_id} or null

        alt Token is blacklisted
            Guard-->>Client: 401 Unauthorized (TokenRevokedException)
        end
    end

    rect rgb(245, 255, 245)
        Note over Guard,Redis: Step 3: Check expiry
        Guard->>Guard: Check exp < now()
        Note right of Guard: jwt.verify checks this automatically

        alt Token expired
            Guard-->>Client: 401 Unauthorized (TokenExpiredException)
        end
    end

    Guard->>Guard: Attach user to request (sub, user_id, role)
    Guard-->>Handler: Request with user context

    Handler->>Handler: Execute route logic
    Handler-->>Client: 200 OK + Response
