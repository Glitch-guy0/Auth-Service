%% Object Diagram - Runtime Instances
%% Maps to: Runtime state during authentication flow

graph TB
    subgraph "Runtime: Authentication Flow"
        subgraph "Request Context"
            REQ["HTTPRequest<br/>━━━━━━━━━━━━━<br/>method: POST<br/>path: /auth/v1/authenticate<br/>body: {email, password}<br/>headers: {}"]
            
            RES["HTTPResponse<br/>━━━━━━━━━━━━━<br/>status: 200<br/>headers: Set-Cookie<br/>body: {accessToken}"]
        end
        
        subgraph "Service Instances"
            AUTH_INST["AuthService<br/>━━━━━━━━━━━━━<br/>userService: UserService<br/>tokenService: TokenService<br/>logger: LoggerService"]
            
            USER_INST["UserService<br/>━━━━━━━━━━━━━<br/>userRepo: UserRepository<br/>cache: CacheService"]
            
            TOKEN_INST["TokenService<br/>━━━━━━━━━━━━━<br/>keyManager: KeyManager<br/>tokenRepo: TokenRepository<br/>redis: RedisService"]
            
            LOG_INST["LoggerService<br/>━━━━━━━━━━━━━<br/>logger: PinoLogger<br/>context: 'AuthService'"]
        end
        
        subgraph "Entity Instances"
            USER_ENTITY["User<br/>━━━━━━━━━━━━━<br/>id: 'uuid-123'<br/>username: 'john_doe'<br/>email: 'john@example.com'<br/>password: '$2b$10$...'<br/>blocked: false<br/>is_verified: true<br/>created_at: 2026-07-12"]
            
            TOKEN_ENTITY["RefreshToken<br/>━━━━━━━━━━━━━<br/>id: 'uuid-456'<br/>user_id: 'uuid-123'<br/>token_hash: '$2b$10$...'<br/>expires_at: 2026-07-19<br/>created_at: 2026-07-12"]
            
            DEMO_ENTITY["UserDemographics<br/>━━━━━━━━━━━━━<br/>user_id: 'uuid-123'<br/>last_ip: '192.168.1.1'<br/>country: 'US'<br/>city: 'San Francisco'<br/>last_login: 2026-07-12"]
        end
        
        subgraph "Adapter Instances"
            PG_INST["PostgreSQL Adapter<br/>━━━━━━━━━━━━━<br/>connection: TypeORM<br/>repository: UserRepository<br/>repository: TokenRepository"]
            
            REDIS_INST["Redis Adapter<br/>━━━━━━━━━━━━━<br/>client: RedisClient<br/>prefix: 'blacklist:'"]
            
            MONGO_INST["MongoDB Adapter<br/>━━━━━━━━━━━━━<br/>connection: Mongoose<br/>collection: 'user_demographics'"]
            
            KEY_INST["KeyManager<br/>━━━━━━━━━━━━━<br/>keys: Map<br/>currentKid: 'kid-2026'<br/>privateKey: PrivateKey<br/>publicKey: PublicKey"]
        end
    end
    
    REQ --> AUTH_INST
    AUTH_INST --> USER_INST
    AUTH_INST --> TOKEN_INST
    AUTH_INST --> LOG_INST
    
    USER_INST --> USER_ENTITY
    USER_INST --> DEMO_ENTITY
    TOKEN_INST --> TOKEN_ENTITY
    
    USER_INST --> PG_INST
    TOKEN_INST --> PG_INST
    TOKEN_INST --> REDIS_INST
    USER_INST --> MONGO_INST
    TOKEN_INST --> KEY_INST
    
    AUTH_INST --> RES
    
    style REQ fill:#4CAF50,color:#fff
    style RES fill:#4CAF50,color:#fff
    
    style AUTH_INST fill:#FF9800,color:#fff
    style USER_INST fill:#FF9800,color:#fff
    style TOKEN_INST fill:#FF9800,color:#fff
    style LOG_INST fill:#FF9800,color:#fff
    
    style USER_ENTITY fill:#2196F3,color:#fff
    style TOKEN_ENTITY fill:#2196F3,color:#fff
    style DEMO_ENTITY fill:#2196F3,color:#fff
    
    style PG_INST fill:#9C27B0,color:#fff
    style REDIS_INST fill:#9C27B0,color:#fff
    style MONGO_INST fill:#9C27B0,color:#fff
    style KEY_INST fill:#9C27B0,color:#fff
