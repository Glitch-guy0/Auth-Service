%% TreeView Diagram - Module Structure
%% Maps to: Section 11.4 Folder Structure, Section 11.5 Internal Library Management
%% Shows hierarchical package organization with interfaces and types
%% Token blacklist is Redis-only (not in PostgreSQL schema)

graph TB
    subgraph src ["src (AuthService)"]
        subgraph Modules
            subgraph auth
                AuthModule
                AuthController
                AuthService
            end
            subgraph user
                UserModule
                UserController
                UserService
            end
            subgraph token
                TokenModule
                TokenService
                AuthTokenEntity
                PublicKeyRegistryEntity
            end
            subgraph logging
                LoggingModule
                LoggerService
            end
        end

        subgraph lib
            subgraph interfaces
                IAuthService
                IUserService
                ITokenService
                ILoggerService
            end
            subgraph types
                subgraph schemas
                    RegisterSchema
                    LoginSchema
                    RefreshTokenSchema
                end
                subgraph dto
                    RegisterDto
                    LoginDto
                    RefreshTokenDto
                end
                subgraph response
                    TokenResponse
                    TokenPair
                    UserResponse
                    JwtPayload
                end
                subgraph builder
                    ReduceBuilder
                end
                subgraph entity
                    UserEntity
                end
            end
            subgraph decorators
                RetryDecorator
                CacheDecorator
                LogDecorator
            end
            subgraph filters
                HttpExceptionFilter
                AllExceptionsFilter
            end
            subgraph guards
                JwtAuthGuard
                RolesGuard
            end
            subgraph interceptors
                LoggingInterceptor
                TimeoutInterceptor
                TransformInterceptor
            end
            subgraph pipes
                ValidationPipe
            end
            subgraph utils
                HashUtil
                UuidUtil
            end
            subgraph transaction
                Transaction
            end
        end

        subgraph Configuration
            subgraph env
                EnvValidator
            end
            subgraph database
                DatabaseConfig
            end
            subgraph context
                AppContext
            end
        end

        subgraph DatabaseLayer
            subgraph migrations
                TypeOrmMigrations
            end
            subgraph seeds
                DatabaseSeeds
            end
        end

        subgraph Schema
            subgraph entities
                UserEntity
                AuthTokenEntity
                PublicKeyRegistryEntity
            end
            subgraph model
                DemographicsModel
                AuditLogModel
                ActivityModel
            end
            subgraph cache
                TokenCache
                SessionCache
                RateLimitCache
            end
        end

        AppModule
        Main
    end

    style src fill:#1a1a2e,color:#fff
    style Modules fill:#16213e,color:#fff
    style lib fill:#0f3460,color:#fff
    style Configuration fill:#533483,color:#fff
    style DatabaseLayer fill:#2b2d42,color:#fff
    style Schema fill:#8d99ae,color:#000
