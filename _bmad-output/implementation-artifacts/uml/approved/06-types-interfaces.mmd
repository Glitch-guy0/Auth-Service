%% Types & Interfaces Diagram
%% Maps to: Hexagonal Architecture, Ports & Adapters
%% Zod schemas, DTOs, Response types, Port interfaces, and type transformations
%% TokenService validates JWT + returns complete JwtPayload

classDiagram
    %% ════════════════════════════════════════════════════════════════
    %%  ZOD VALIDATION SCHEMAS
    %% ════════════════════════════════════════════════════════════════
    class RegisterSchema {
        <<Zod Schema>>
        +email: z.string().email()
        +username?: z.string().min(3).max(20)
        +password: z.string().min(8).max(20)
    }

    class LoginSchema {
        <<Zod Schema>>
        +email?: z.string().email()
        +username?: z.string().min(3).max(20)
        +password: z.string().min(8).max(20)
    }

    class RefreshTokenSchema {
        <<Zod Schema>>
        +refreshToken: z.string().jwt()
    }

    %% ════════════════════════════════════════════════════════════════
    %%  DTOs (Inferred from Zod)
    %% ════════════════════════════════════════════════════════════════
    class RegisterDto {
        <<DTO from Zod>>
        +email: string
        +password: string
        +username: string
    }

    class LoginDto {
        <<DTO from Zod>>
        +email?: string
        +username?: string
        +password: string
    }

    class RefreshTokenDto {
        <<DTO from Zod>>
        +refreshToken: string
    }

    %% ════════════════════════════════════════════════════════════════
    %%  RESPONSE / TRANSFORM TYPES
    %% ════════════════════════════════════════════════════════════════
    class TokenResponse {
        <<Response Type>>
        +accessToken: string
        +refreshToken: string
        +expiresIn: number
    }

    class TokenPair {
        <<Internal Type>>
        +accessToken: string
        +refreshToken: string
    }

    class JwtPayload {
        <<Internal Type>>
        +sub: string
        +iat: number
        +iss: string
        +kid: string
        +exp: number
        +user_id: string
    }

    class UserResponse {
        <<Response Type>>
        +id: string
        +username: string
        +email: string
        +isVerified: boolean
        +createdAt: Date
    }

    class ReduceBuilder {
        <<Builder>>
        -entity: Entity
        -selectedFields: string[]
        +select(...fields: string[]): ReduceBuilder
        +execute(): Response
    }

    %% ════════════════════════════════════════════════════════════════
    %%  PORT INTERFACES (only those used by types)
    %% ════════════════════════════════════════════════════════════════
    class IAuthService {
        <<Port Interface>>
        +register(dto: RegisterDto): Promise~TokenResponse~
        +login(dto: LoginDto): Promise~TokenResponse~
        +refresh(dto: RefreshTokenDto): Promise~TokenResponse~
        +logout(accessToken: string): Promise~void~
    }

    class IUserService {
        <<Port Interface>>
        +findByEmail(email: string): Promise~UserEntity~
        +findByUsername(username: string): Promise~UserEntity~
        +findById(id: string): Promise~UserEntity~
        +create(dto: RegisterDto): Promise~UserEntity~
        +reduce(entity: UserEntity): ReduceBuilder
    }

    class ITokenService {
        <<Port Interface>>
        +generateTokenPair(user: UserEntity): Promise~TokenPair~
        +validateRefreshToken(token: string): Promise~JwtPayload
        +blacklistToken(token: string): Promise~void~
        +isBlacklisted(accessToken: string): Promise~boolean~
    }

    %% ════════════════════════════════════════════════════════════════
    %%  ENTITY
    %% ════════════════════════════════════════════════════════════════
    class UserEntity {
        <<Entity>>
        +id: UUID
        +username: string
        +email: string
        +password: string
        +blocked: boolean
        +isDeleted: boolean
        +isVerified: boolean
        +createdAt: Date
        +updatedAt: Date
    }

    %% ════════════════════════════════════════════════════════════════
    %%  TYPE RELATIONSHIPS
    %% ════════════════════════════════════════════════════════════════

    %% Schema to DTO (z.infer)
    RegisterSchema ..> RegisterDto : z.infer
    LoginSchema ..> LoginDto : z.infer
    RefreshTokenSchema ..> RefreshTokenDto : z.infer

    %% DTO to Interface (flow)
    RegisterDto --> IAuthService : passed to
    LoginDto --> IAuthService : passed to
    RefreshTokenDto --> IAuthService : passed to

    %% Entity to Interface (flow)
    UserEntity --> ITokenService : passed to
    TokenPair --> ITokenService : returned
    JwtPayload --> ITokenService : returned by validateRefreshToken

    %% Entity transformations
    UserEntity ..> ReduceBuilder : reduce()
    ReduceBuilder ..> UserResponse : select().execute()
    TokenPair ..> TokenResponse : reduce()
