%% Service Class Diagram
%% Maps to: Hexagonal Architecture, Ports & Adapters
%% Intermediate types: Zod schemas, DTOs, Entity unions, Type utilities

classDiagram
    %% ════════════════════════════════════════════════════════════════
    %%  ZOD VALIDATION SCHEMAS
    %% ════════════════════════════════════════════════════════════════
    class RegisterSchema {
        <<Zod Schema>>
        +email: z.string().email()
        +username?: z.string().min(3).max(20)
        +password: z.string().min(8).max(20)
    }

    class LoginSchema {
        <<Zod Schema>>
        +email?: z.string().email()
        +username?: z.string().min(3).max(20)
        +password: z.string().min(8).max(20)
    }

    class RefreshTokenSchema {
        <<Zod Schema>>
        +refreshToken: z.string().jwt()
    }

    %% ════════════════════════════════════════════════════════════════
    %%  DTOs (Inferred from Zod)
    %% ════════════════════════════════════════════════════════════════
    class RegisterDto {
        <<DTO from Zod>>
        +email: string
        +password: string
        +username: string
    }

    class LoginDto {
        <<DTO from Zod>>
        +email?: string
        +username?: string
        +password: string
    }

    class RefreshTokenDto {
        <<DTO from Zod>>
        +refreshToken: string
    }

    %% ════════════════════════════════════════════════════════════════
    %%  RESPONSE / TRANSFORM TYPES
    %% ════════════════════════════════════════════════════════════════
    class TokenResponse {
        <<Response Type>>
        +accessToken: string
        +refreshToken: string
        +expiresIn: number
    }

    class TokenPair {
        <<Internal Type>>
        +accessToken: string
        +refreshToken: string
    }

    class UserResponse {
        <<Response Type>>
        +id: string
        +username: string
        +email: string
        +isVerified: boolean
        +createdAt: Date
    }

    class ReduceBuilder {
        <<Builder>>
        -entity: Entity
        -selectedFields: string[]
        +select(...fields: string[]): ReduceBuilder
        +execute(): Response
    }

    class UserEntity {
        <<Entity>>
        +id: UUID
        +username: string
        +email: string
        +password: string
        +blocked: boolean
        +isDeleted: boolean
        +isVerified: boolean
        +createdAt: Date
        +updatedAt: Date
    }

    %% ════════════════════════════════════════════════════════════════
    %%  PORT INTERFACES
    %% ════════════════════════════════════════════════════════════════
    class IAuthService {
        <<Port Interface>>
        +register(dto: RegisterDto): Promise~TokenResponse~
        +login(dto: LoginDto): Promise~TokenResponse~
        +refresh(dto: RefreshTokenDto): Promise~TokenResponse~
        +logout(accessToken: string): Promise~void~
    }

    class IUserService {
        <<Port Interface>>
        +findByEmail(email: string): Promise~UserEntity~
        +findByUsername(username: string): Promise~UserEntity~
        +findById(id: string): Promise~UserEntity~
        +create(dto: RegisterDto): Promise~UserEntity~
        +reduce(entity: UserEntity): ReduceBuilder
    }

    class ITokenService {
        <<Port Interface>>
        +generateTokenPair(user: UserEntity): Promise~TokenPair~
        +validateRefreshToken(token: string): Promise~boolean~
        +blacklistToken(token: string): Promise~void~
        +isBlacklisted(jti: string): Promise~boolean~
    }

    class ILoggerService {
        <<Port Interface>>
        +debug(message: string, context?: string): void
        +info(message: string, context?: string): void
        +warn(message: string, context?: string): void
        +error(message: string, context?: string): void
        +fatal(message: string, context?: string): void
    }

    %% ════════════════════════════════════════════════════════════════
    %%  SERVICE IMPLEMENTATIONS
    %% ════════════════════════════════════════════════════════════════
    class AuthService {
        -userService: IUserService
        -tokenService: ITokenService
        -logger: ILoggerService
        +register(dto: RegisterDto): Promise~TokenResponse~
        +login(dto: LoginDto): Promise~TokenResponse~
        +refresh(dto: RefreshTokenDto): Promise~TokenResponse~
        +logout(accessToken: string): Promise~void~
        -hashPassword(password: string): Promise~string~
        -verifyPassword(password: string, hash: string): Promise~boolean~
    }

    class UserService {
        -userRepo: UserRepository
        -cache: CacheService
        +findByEmail(email: string): Promise~UserEntity~
        +findByUsername(username: string): Promise~UserEntity~
        +findById(id: string): Promise~UserEntity~
        +create(dto: RegisterDto): Promise~UserEntity~
        +reduce(entity: UserEntity): ReduceBuilder
    }

    class TokenService {
        -keyManager: KeyManager
        -tokenRepo: TokenRepository
        -redis: RedisService
        +generateTokenPair(user: UserEntity): Promise~TokenPair~
        +validateRefreshToken(token: string): Promise~boolean~
        +blacklistToken(token: string): Promise~void~
        +isBlacklisted(jti: string): Promise~boolean~
        -signAccessToken(user: UserEntity): string
        -hashToken(token: string): string
    }

    class LoggerService {
        -logger: PinoLogger
        +debug(message: string, context?: string): void
        +info(message: string, context?: string): void
        +warn(message: string, context?: string): void
        +error(message: string, context?: string): void
        +fatal(message: string, context?: string): void
    }

    class KeyManager {
        -keys: Map~string, KeyPair~
        +getPrivateKey(): PrivateKey
        +getPublicKey(): PublicKey
        +getCurrentKid(): string
        -loadKeys(): void
        -clearPrivateKey(): void
    }

    %% ════════════════════════════════════════════════════════════════
    %%  RELATIONSHIPS
    %% ════════════════════════════════════════════════════════════════

    %% Schema to DTO (z.infer)
    RegisterSchema ..> RegisterDto : z.infer
    LoginSchema ..> LoginDto : z.infer
    RefreshTokenSchema ..> RefreshTokenDto : z.infer

    %% DTO usage
    RegisterDto --> IAuthService : passed to
    LoginDto --> IAuthService : passed to
    RefreshTokenDto --> IAuthService : passed to

    %% Interface implementation
    IAuthService <|.. AuthService
    IUserService <|.. UserService
    ITokenService <|.. TokenService
    ILoggerService <|.. LoggerService

    %% Service dependencies
    AuthService --> IUserService : uses
    AuthService --> ITokenService : uses
    AuthService --> ILoggerService : logs to

    %% Entity transformations
    UserEntity ..> ReduceBuilder : reduce()
    ReduceBuilder ..> UserResponse : select().execute()
    TokenPair ..> TokenResponse : reduce()

    %% Repository/Adapter dependencies
    UserService --> UserRepository : persists
    TokenService --> TokenRepository : persists
    TokenService --> RedisService : caches
    TokenService --> KeyManager : signs with
