%% Service Class Diagram
%% Maps to: Hexagonal Architecture, Ports & Adapters

classDiagram
    class IAuthService {
        <<Port Interface>>
        +register(dto: RegisterDto): Promise~TokenResponse~
        +login(dto: LoginDto): Promise~TokenResponse~
        +refresh(refreshToken: string): Promise~TokenResponse~
        +logout(accessToken: string): Promise~void~
    }
    
    class AuthService {
        -UserService userService
        -TokenService tokenService
        -LoggerService logger
        +register(dto: RegisterDto): Promise~TokenResponse~
        +login(dto: LoginDto): Promise~TokenResponse~
        +refresh(refreshToken: string): Promise~TokenResponse~
        +logout(accessToken: string): Promise~void~
        -hashPassword(password: string): Promise~string~
        -verifyPassword(password: string, hash: string): Promise~boolean~
    }
    
    class IUserService {
        <<Port Interface>>
        +findByEmail(email: string): Promise~User~
        +findByUsername(username: string): Promise~User~
        +findById(id: string): Promise~User~
        +create(dto: CreateUserDto): Promise~User~
        +update(id: string, dto: UpdateUserDto): Promise~User~
    }
    
    class UserService {
        -UserRepository userRepo
        -CacheService cache
        +findByEmail(email: string): Promise~User~
        +findByUsername(username: string): Promise~User~
        +findById(id: string): Promise~User~
        +create(dto: CreateUserDto): Promise~User~
        +update(id: string, dto: UpdateUserDto): Promise~User~
    }
    
    class ITokenService {
        <<Port Interface>>
        +generateTokenPair(user: User): Promise~TokenPair~
        +validateRefreshToken(token: string): Promise~boolean~
        +blacklistToken(token: string): Promise~void~
        +isBlacklisted(jti: string): Promise~boolean~
    }
    
    class TokenService {
        -KeyManager keyManager
        -TokenRepository tokenRepo
        -RedisService redis
        +generateTokenPair(user: User): Promise~TokenPair~
        +validateRefreshToken(token: string): Promise~boolean~
        +blacklistToken(token: string): Promise~void~
        +isBlacklisted(jti: string): Promise~boolean~
        -signAccessToken(user: User): string
        -hashToken(token: string): string
    }
    
    class ILoggerService {
        <<Port Interface>>
        +debug(message: string, context?: string): void
        +info(message: string, context?: string): void
        +warn(message: string, context?: string): void
        +error(message: string, context?: string): void
        +fatal(message: string, context?: string): void
    }
    
    class LoggerService {
        -PinoLogger logger
        +debug(message: string, context?: string): void
        +info(message: string, context?: string): void
        +warn(message: string, context?: string): void
        +error(message: string, context?: string): void
        +fatal(message: string, context?: string): void
    }
    
    class KeyManager {
        -Map~string, KeyPair~ keys
        +getPrivateKey(): PrivateKey
        +getPublicKey(): PublicKey
        +getCurrentKid(): string
        -loadKeys(): void
        -clearPrivateKey(): void
    }
    
    IAuthService <|.. AuthService
    IUserService <|.. UserService
    ITokenService <|.. TokenService
    ILoggerService <|.. LoggerService
    
    AuthService --> IUserService : uses
    AuthService --> ITokenService : uses
    AuthService --> ILoggerService : logs to
    
    UserService --> UserRepository : persists
    TokenService --> TokenRepository : persists
    TokenService --> RedisService : caches
    TokenService --> KeyManager : signs with
