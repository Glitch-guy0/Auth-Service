%% Redis Token Blacklist (Redis-only, not in PostgreSQL)
%% Maps to: FR-4, FR-25
%% Storage: Redis with TTL matching token expiry
%% Note: Best-effort — if Redis is down, access token remains valid until natural expiry

graph TB
    subgraph "Redis Blacklist Storage"
        subgraph "Key Pattern: blacklist:{access_token}"
            BL_ENTRY["BlacklistEntry<br/>━━━━━━━━━━━━<br/>key: blacklist:{access_token}<br/>value: {expires_at, user_id}<br/>TTL: token_expiry_time"]
        end

        subgraph "Operations"
            SET_CMD["SET blacklist:{access_token} {expires_at, user_id}<br/>━━━━━━━━━━━━<br/>TTL = token remaining expiry"]
            GET_CMD["GET blacklist:{access_token}<br/>━━━━━━━━━━━━<br/>Returns: {expires_at, user_id} or null"]
            DEL_CMD["DEL blacklist:{access_token}<br/>━━━━━━━━━━━━<br/>Manual removal (admin use)"]
        end
    end

    subgraph "Usage Points"
        LOGOUT["Logout Flow<br/>━━━━━━━━━━━━<br/>POST /auth/v1/logout<br/>Best-effort: if Redis down, 200 OK still sent"]
        MIDDLEWARE["Auth Guard<br/>━━━━━━━━━━━━<br/>Check blacklist before<br/>accepting access token"]
    end

    SET_CMD --> BL_ENTRY
    LOGOUT --> SET_CMD
    MIDDLEWARE --> GET_CMD
    BL_ENTRY -.->|"Auto-expiry via TTL"| DEL_CMD

    style BL_ENTRY fill:#F44336,color:#fff
    style SET_CMD fill:#4CAF50,color:#fff
    style GET_CMD fill:#2196F3,color:#fff
    style DEL_CMD fill:#FF9800,color:#fff
    style LOGOUT fill:#9C27B0,color:#fff
    style MIDDLEWARE fill:#9C27B0,color:#fff
