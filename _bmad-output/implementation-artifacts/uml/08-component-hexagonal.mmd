    style LOG_PORT fill:#2196F3,color:#fff
    
    style AUTH_SVC fill:#FF9800,color:#fff
    style USER_SVC fill:#FF9800,color:#fff
    style TOKEN_SVC fill:#FF9800,color:#fff
    style LOG_SVC fill:#FF9800,color:#fff
    
