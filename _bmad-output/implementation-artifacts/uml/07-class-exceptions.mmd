# Exception Hierarchy Class Diagram
# Maps to: Section 11.1 Exception Handling Strategy

classDiagram
    class BaseAuthException {
        <<abstract>>
        +string code
        +string message
        +number statusCode
        +getErrorCode(): string
        +getErrorMessage(): string
        +getHttpStatus(): number
    }
    
    class AuthenticationException {
        +string code = "AUTH_ERROR"
        +number statusCode = 401
    }
    
    class InvalidCredentialsException {
        +string code = "AUTH_INVALID_CREDENTIALS"
        +string message = "Invalid email/username or password"
    }
    
    class TokenExpiredException {
        +string code = "TOKEN_EXPIRED"
        +string message = "Token has expired"
    }
    
    class TokenRevokedException {
        +string code = "TOKEN_REVOKED"
        +string message = "Token has been revoked"
    }
    
    class AuthorizationException {
        +string code = "AUTH_ERROR"
        +number statusCode = 403
    }
    
    class UserBlockedException {
        +string code = "AUTH_USER_BLOCKED"
        +string message = "User account is blocked"
    }
    
    class ValidationException {
        +string code = "VALIDATION_ERROR"
        +number statusCode = 400
    }
    
    class UserExistsException {
        +string code = "AUTH_USER_EXISTS"
        +string message = "User with this email/username already exists"
    }
    
    class InvalidEmailException {
        +string code = "VALIDATION_EMAIL"
        +string message = "Invalid email format"
    }
    
    class WeakPasswordException {
        +string code = "VALIDATION_PASSWORD"
        +string message = "Password does not meet requirements"
    }
    
    class NotFoundException {
        +string code = "NOT_FOUND"
        +number statusCode = 404
    }
    
    class UserNotFoundException {
        +string code = "AUTH_USER_NOT_FOUND"
        +string message = "User not found"
    }
    
    class RateLimitException {
        +string code = "RATE_LIMIT"
        +number statusCode = 429
    }
    
    class TooManyRequestsException {
        +string code = "RATE_LIMIT_EXCEEDED"
        +string message = "Too many requests, please try again later"
    }
    
    BaseAuthException <|-- AuthenticationException
    BaseAuthException <|-- AuthorizationException
    BaseAuthException <|-- ValidationException
    BaseAuthException <|-- NotFoundException
    BaseAuthException <|-- RateLimitException
    
    AuthenticationException <|-- InvalidCredentialsException
    AuthenticationException <|-- TokenExpiredException
    AuthenticationException <|-- TokenRevokedException
    
    AuthorizationException <|-- UserBlockedException
    
    ValidationException <|-- UserExistsException
    ValidationException <|-- InvalidEmailException
    ValidationException <|-- WeakPasswordException
    
    NotFoundException <|-- UserNotFoundException
    
    RateLimitException <|-- TooManyRequestsException
    
    note for BaseAuthException "Abstract base class<br/>All auth exceptions extend this<br/>Provides consistent error response format"
    note for AuthenticationException "401 Unauthorized<br/>For authentication failures"
    note for AuthorizationException "403 Forbidden<br/>For authorization failures"
    note for ValidationException "400 Bad Request<br/>For input validation errors"
    note for NotFoundException "404 Not Found<br/>For resource not found"
    note for RateLimitException "429 Too Many Requests<br/>For rate limiting"
