# ============================================
# AuthService Environment Configuration
# ============================================
# Copy this file to .env — all values work out of the box with docker-compose.yml.
# All variables are validated on startup via src/config/env.validator.ts.

# --- Database Connections ---

# PostgreSQL (matches docker-compose: authuser/authpass@localhost:5432/authservice)
DATABASE_URL=postgresql://authuser:authpass@localhost:5432/authservice

# MongoDB (matches docker-compose: localhost:27017/authservice)
MONGODB_URL=mongodb://localhost:27017/authservice

# Redis (matches docker-compose: localhost:6379)
REDIS_URL=redis://localhost:6379

# --- JWT Configuration ---

# Access token expiry (parsed by jose — e.g. '15m', '1h', '1d')
JWT_ACCESS_EXPIRY=1d

# Refresh token expiry (7 days — rotated on each use)
JWT_REFRESH_EXPIRY=7d

# --- Security ---

# bcrypt cost factor (4–31; use 4 in tests for speed, 10+ in dev/prod)
BCRYPT_COST=10

# --- Server ---

# Port the application listens on
PORT=3000

# Node environment: development | production | test
NODE_ENV=development

# --- Logging ---

# Pino log level: debug | info | warn | error | fatal
LOG_LEVEL=info
